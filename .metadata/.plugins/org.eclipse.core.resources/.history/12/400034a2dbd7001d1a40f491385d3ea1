package p1.ejercicio5;

import java.time.LocalDate;
import java.util.ArrayList;
import java.util.List;

public class Directorio extends FileSystem {
	
	private List<System> archivos = new ArrayList<>();
	
	/**
	 *	Crea un nuevo Directorio con nombre <nombre> y en la fecha <fecha>.
	 */
    public Directorio(String nombre, LocalDate fecha) {
    	this.nombre = nombre;
    	this.fecha = fecha;
    }

    /**
	 * Retorna el espacio total ocupado, incluyendo su contenido.
	 */
    public int tamanoTotalOcupado() {
    	if (archivos.size() == 0) {
    		return 0;
    	} else {
    		this.archivos.stream().mapToInt(archivo -> archivo.getTamanio()).sum();
    	}
    }
    
